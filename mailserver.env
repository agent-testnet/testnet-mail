# Mail server FQDN. Use a sub-domain (mail.<domain>) -- NOT the bare mail
# domain itself. docker-mailserver puts this into Postfix's $myhostname,
# and $myhostname is referenced by mydestination. If $myhostname equals the
# virtual mailbox domain, Postfix routes inbound mail through the `local`
# transport (which only knows Unix users) instead of `virtual` -> Dovecot
# LMTP, and every delivery bounces with "unknown user". scripts/deploy.sh
# rewrites this line at deploy time to "mail.${MAIL_DOMAIN}".
OVERRIDE_HOSTNAME=mail.gmail.com

ENABLE_CLAMAV=0
ENABLE_RSPAMD=0
ENABLE_AMAVIS=0
ENABLE_SPAMASSASSIN=0
ENABLE_FAIL2BAN=0
ENABLE_POSTGREY=0
ENABLE_QUOTAS=0
ENABLE_MANAGESIEVE=0
ENABLE_UPDATE_CHECK=0

ENABLE_SRS=0

ENABLE_OPENDKIM=0
ENABLE_OPENDMARC=0
ENABLE_POLICYD_SPF=0

PERMIT_DOCKER=connected-networks

RELAY_HOST=
DEFAULT_RELAY_HOST=

MAILBOX_FORMAT=maildir

LOG_LEVEL=warn

POSTFIX_MESSAGE_SIZE_LIMIT=26214400

SPOOF_PROTECTION=0
